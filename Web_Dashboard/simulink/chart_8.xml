        <P Name="isEML">1</P>
        <P Name="script">function D = mppt_po(Vpv, Ipv)
    % 1. Persistent variables to store historical values between time-steps
    persistent P_old V_old D_old;
    
    % 2. Protect against flipped sensor polarities by forcing absolute values
    Vpv = abs(Vpv);
    Ipv = abs(Ipv);
    
    % 3. Safe initialization on the very first simulation step
    if isempty(P_old)
        P_old = 0;
        V_old = 0;
        D_old = 0.45; % Start in the middle
    end
    
    % 4. Calculate current power
    P_new = Vpv * Ipv;
    
    % 5. Calculate the changes (deltas)
    delta_P = P_new - P_old;
    delta_V = Vpv - V_old;
    
    % 6. Tracking step size (0.002 keeps it stable)
    step = 0.002; 
    
    % 7. SWAPPED P&amp;O SIGN LOGIC (Forces the duty cycle to climb correctly)
    if delta_P &gt; 0
        if delta_V &gt; 0
            D = D_old + step; % Power up, Voltage up -&gt; Increase D
        else
            D = D_old - step; % Power up, Voltage down -&gt; Decrease D
        end
    else
        if delta_V &gt; 0
            D = D_old - step; % Power down, Voltage up -&gt; Decrease D
        else
            D = D_old + step; % Power down, Voltage down -&gt; Increase D
        end
    end
    
    % 8. Boundary Protection: Keep D locked in a healthy operational window
    if D &gt; 0.85
        D = 0.85; 
    elseif D &lt; 0.15
        D = 0.15; 
    end
    
    % 9. Update history tracking variables for the next time-step execution
    P_old = P_new;
    V_old = Vpv;
    D_old = D;
end</P>
      </eml>
    </state>
